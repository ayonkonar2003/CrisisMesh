<% layout('layouts/boilerplate') %>

<div class="py-5 text-center">
    <h1 class="hero-title">
        Community-Driven <br>
        <span class="text-danger">Emergency Response</span>
    </h1>
    <p class="hero-subtitle">
        CrisisMesh connects urgent needs with nearby resources through open innovation and community collaboration.
    </p>
    <div class="d-flex flex-wrap justify-content-center gap-3">
        <a href="/requests/new" class="btn btn-primary btn-lg shadow-lg">I Need Help</a>
        <a href="/offers/new" class="btn btn-outline-dark btn-lg">I Can Offer Help</a>
    </div>
</div>

<div class="row g-4 mt-5">
    <div class="col-md-4">
        <div class="card h-100 p-3">
            <div class="card-body">
                <div class="brand-icon mb-4" style="background-color: #fee2e2; color: #ef4444;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
                </div>
                <h3 class="h5 fw-bold">Report Needs</h3>
                <p class="text-muted small">Post urgent requirements for food, medical aid, or shelter in your area.</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 p-3">
            <div class="card-body">
                <div class="brand-icon mb-4" style="background-color: #dcfce7; color: #10b981;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m8 3 4 8 5-5 5 15H2L8 3z"/></svg>
                </div>
                <h3 class="h5 fw-bold">Offer Resources</h3>
                <p class="text-muted small">Register available supplies or services to help those in distress.</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 p-3">
            <div class="card-body">
                <div class="brand-icon mb-4" style="background-color: #dbeafe; color: #3b82f6;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/></svg>
                </div>
                <h3 class="h5 fw-bold">Smart Matching</h3>
                <p class="text-muted small">Our system automatically connects relevant offers with reported needs.</p>
            </div>
        </div>
    </div>
</div>
