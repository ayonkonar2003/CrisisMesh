<% layout('layouts/boilerplate') %>
<div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-5 gap-3">
    <h1 class="fw-bold tracking-tight mb-0">Emergency Requests</h1>
    <div class="d-flex gap-2 w-100 w-md-auto">
        <form action="/requests" method="GET" class="d-flex gap-2 flex-grow-1">
            <select name="location" class="form-select form-select-sm" onchange="this.form.submit()">
                <option value="">All Locations</option>
                <%- include('../partials/city-datalist', { selectedValue: typeof location !== 'undefined' ? location : '' }) %>
            </select>
        </form>
        <a href="/requests/new" class="btn btn-primary btn-sm d-flex align-items-center whitespace-nowrap">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-1"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
            New Request
        </a>
    </div>
</div>

<div class="row g-4">
    <% for (let request of requests) { %>
    <div class="col-md-6 col-lg-4">
        <div class="card h-100 border-0 shadow-sm position-relative">
            <% if(request.image) { %>
                <img src="<%= request.image %>" referrerPolicy="no-referrer" class="card-img-top" alt="<%= request.title %>" style="height: 180px; object-fit: cover;">
            <% } %>
            <% if(request.status === 'resolved') { %>
                <div class="position-absolute top-0 end-0 bg-success text-white px-3 py-1 small fw-bold rounded-bl-xl" style="border-bottom-left-radius: 16px; font-size: 0.65rem; letter-spacing: 0.05em;">
                    RESOLVED
                </div>
            <% } %>
            <div class="card-body d-flex flex-column">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="badge bg-<%= request.urgency === 'Critical' ? 'danger' : 'warning' %> text-<%= request.urgency === 'Critical' ? 'white' : 'dark' %>">
                        <%= request.urgency %>
                    </span>
                    <span class="text-muted small fw-bold text-uppercase" style="font-size: 0.6rem;"><%= request.category %></span>
                </div>
                <h5 class="card-title fw-bold mb-2"><%= request.title %></h5>
                <div class="d-flex align-items-center text-muted small mb-3">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-1"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                    <%= request.location %>
                </div>
                <p class="card-text text-muted small mb-4 flex-grow-1">
                    <%= request.description.length > 120 ? request.description.substring(0, 120) + '...' : request.description %>
                </p>
                <div class="d-flex justify-content-between align-items-center pt-3 border-top mt-auto">
                    <div class="d-flex align-items-center text-muted" style="font-size: 0.7rem;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-1 text-primary"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/></svg>
                        <%= request.verifiedCount %> verified
                    </div>
                    <a href="/requests/<%= request.id %>" class="btn btn-link p-0 text-decoration-none fw-bold text-primary small d-flex align-items-center">
                        View Details
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ms-1"><path d="m9 18 6-6-6-6"/></svg>
                    </a>
                </div>
            </div>
        </div>
    </div>
    <% } %>
    <% if(requests.length === 0) { %>
        <div class="col-12 py-5 text-center">
            <p class="text-muted italic">No active requests found.</p>
        </div>
    <% } %>
</div>
